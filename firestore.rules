rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chat messages (used by the in-page Community chat modal in index.html /
    // assets/js/community.js). No Auth is used; validate the exact
    // payload shape. `ts` is a numeric epoch-ms value.
    match /messages/{messageId} {
      allow read: if true;

      allow create: if request.resource.data.size() <= 8
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 24
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.uid is string
        && request.resource.data.color is string
        && request.resource.data.id is string
        && (request.resource.data.ts is int || request.resource.data.ts is float)
        && (request.resource.data.location == null || request.resource.data.location is string)
        && (request.resource.data.device == null || request.resource.data.device is string);

      // Visitors cannot edit or delete messages
      allow update, delete: if false;
    }

    // Presence (online users)
    match /presence/{userId} {
      allow read: if true;

      allow create, update: if
        request.resource.data.keys().hasOnly([
          'displayName',
          'x',
          'y',
          'online',
          'lastSeen'
        ]);

      allow delete: if false;
    }

    // User profile
    match /users/{userId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly([
          'displayName',
          'createdAt'
        ]);

      allow update, delete: if false;
    }

    // Everything else is denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}